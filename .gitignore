# Local secrets / env (docker compose auto-loads ./.env). Never commit real
# secrets; see .env.example for the required variables.
.env

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directory
# https://docs.npmjs.com/cli/shrinkwrap#caveats
node_modules

# Debug log from npm
npm-debug.log

# All host-side app state + docker-compose runtime volumes (auth, tags, pics,
# the sprite/thumb cache, meili, redis) are consolidated here. The example prod
# compose also lives here and is intentionally untracked (local-only).
/debug-data
*.swp

/.opencode/
/.claude/
/.qwen/
/.gemini/

# Working scratch / local-only docs (never committed). TODO.md + TODO-DONE.md
# are the project todo + completed-work log; AGENTS.md / GEMINI.md are local
# AI-assistant instruction files kept out of the public repo.
/TODO.md
/TODO-DONE.md
/AGENTS.md
/GEMINI.md
